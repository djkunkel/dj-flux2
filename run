#!/usr/bin/env bash
# run — launch a project command with the correct GPU backend.
#
# Usage:
#   ./run gui                               Launch the GUI
#   ./run generate "prompt" [args]          Generate an image from text
#   ./run img2img "prompt" -i in.png [args] Transform an image
#   ./run upscale -i in.png -o out.png      Upscale an image
#   ./run download                          Download models
#   ./run python <args>                     Run arbitrary python in the venv
#
# Reads .gpu-backend written by ./setup to determine which extra to use
# and which env vars to set. Run ./setup <backend> first.
#
# For generate and img2img, all extra flags are forwarded to generate_image.py.
# See: ./run generate --help

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
BACKEND_FILE="${REPO_DIR}/.gpu-backend"
CONF_FILE="${REPO_DIR}/.dj-flux2.conf"

# Valid config keys and their constraints (used by the config subcommand)
VALID_MODELS="flux.2-klein-4b flux.2-klein-9b flux.2-klein-9b-kv flux.2-klein-base-4b flux.2-klein-base-9b"
DISTILLED_MODELS="flux.2-klein-4b flux.2-klein-9b flux.2-klein-9b-kv"

die()  { echo "error: $*" >&2; exit 1; }
usage() {
    echo "Usage: ./run <command> [args]"
    echo ""
    echo "Commands:"
    echo "  gui                   Launch the interactive GUI"
    echo "  generate  <prompt>    Text-to-image generation"
    echo "  img2img   <prompt>    Image-to-image transformation (requires -i input.png)"
    echo "  upscale               Upscale an image (requires -i input.png -o output.png)"
    echo "  download              Download models"
    echo "  config [key [value]]  View or set default config (model, steps, guidance, width, height)"
    echo "  python    <args>      Run arbitrary python in the project venv"
    echo ""
    echo "Run ./setup <backend> first if you haven't already."
    exit 1
}

# Read .gpu-backend
if [[ ! -f "$BACKEND_FILE" ]]; then
    die "No backend configured. Run ./setup <backend> first."
fi
backend=$(cat "$BACKEND_FILE" | tr -d '[:space:]')

# Determine the uv extra to pass. rocm-nightly uses the stable rocm extra
# (torch is already installed by ./setup; --no-sync keeps it in place).
case "$backend" in
    cuda|rocm|cpu) uv_extra="$backend" ;;
    rocm-nightly)  uv_extra="rocm" ;;
    *) die "Unknown backend '$backend' in $BACKEND_FILE. Re-run ./setup." ;;
esac

# Set RDNA4-specific env vars when using rocm-nightly.
if [[ "$backend" == "rocm-nightly" ]]; then
    # AOTriton flash attention — required for gfx1201
    export TORCH_ROCM_AOTRITON_ENABLE_EXPERIMENTAL=1
    # FAST mode required — NORMAL hangs the GPU on gfx1201 VAE shapes
    export MIOPEN_FIND_MODE=FAST
    # Reduces workspace retention between generations
    export MIOPEN_FIND_ENFORCE=NONE
    # Flush idle blocks at 80% of reserved memory; cap block size to 512 MB
    export PYTORCH_ALLOC_CONF=garbage_collection_threshold:0.8,max_split_size_mb:512
fi

# Choose uv run flags. rocm-nightly uses --no-sync to preserve the nightly
# torch wheel that ./setup installed outside the lockfile.
if [[ "$backend" == "rocm-nightly" ]]; then
    uv_flags="--extra ${uv_extra} --no-sync"
else
    uv_flags="--extra ${uv_extra}"
fi

# ---------------------------------------------------------------------------
# Config helpers
# ---------------------------------------------------------------------------

conf_read() {
    # Read a key from .dj-flux2.conf, print its value, or empty string if unset
    local key="$1"
    [[ -f "$CONF_FILE" ]] || return 0
    grep -m1 "^${key}=" "$CONF_FILE" | cut -d= -f2- || true
}

conf_write() {
    # Set key=value in .dj-flux2.conf, creating or updating the entry
    local key="$1" value="$2"
    if [[ -f "$CONF_FILE" ]] && grep -q "^${key}=" "$CONF_FILE"; then
        sed -i "s|^${key}=.*|${key}=${value}|" "$CONF_FILE"
    else
        echo "${key}=${value}" >> "$CONF_FILE"
    fi
}

conf_print_all() {
    echo "Config file: ${CONF_FILE}"
    echo ""
    if [[ ! -f "$CONF_FILE" ]]; then
        echo "  (no config set — all values use built-in defaults)"
        return
    fi
    local content
    content=$(grep -v '^\s*$' "$CONF_FILE" 2>/dev/null || true)
    if [[ -z "$content" ]]; then
        echo "  (no config set — all values use built-in defaults)"
    else
        echo "$content"
    fi
}

conf_validate_model() {
    local value="$1"
    for m in $VALID_MODELS; do
        [[ "$m" == "$value" ]] && return 0
    done
    die "Invalid model '${value}'. Valid models: $(echo $VALID_MODELS | tr ' ' ', ')"
}

conf_validate_positive_int() {
    local key="$1" value="$2"
    [[ "$value" =~ ^[0-9]+$ ]] || die "${key} must be a positive integer (got '${value}')"
    (( value > 0 )) || die "${key} must be greater than 0 (got '${value}')"
}

conf_validate_positive_float() {
    local key="$1" value="$2"
    [[ "$value" =~ ^[0-9]+(\.[0-9]+)?$ ]] || die "${key} must be a positive number (got '${value}')"
    # Use awk for float comparison
    awk -v v="$value" 'BEGIN { if (v <= 0) exit 1 }' || die "${key} must be greater than 0 (got '${value}')"
}

conf_validate_dimension() {
    local key="$1" value="$2"
    [[ "$value" =~ ^[0-9]+$ ]] || die "${key} must be a positive integer (got '${value}')"
    (( value > 0 )) || die "${key} must be greater than 0"
    (( value <= 2048 )) || die "${key} must be 2048 or under (got '${value}')"
    (( value % 16 == 0 )) || echo "warning: ${key}=${value} is not a multiple of 16; FLUX may round it" >&2
}

conf_warn_if_distilled() {
    local key="$1" model
    model=$(conf_read model)
    [[ -z "$model" ]] && return 0
    for m in $DISTILLED_MODELS; do
        if [[ "$m" == "$model" ]]; then
            echo "warning: '${key}' is ignored for distilled model '${model}' (guidance and steps are baked in)" >&2
            return 0
        fi
    done
}

# ---------------------------------------------------------------------------

cmd="${1:-}"
shift || true

case "$cmd" in
    gui)
        exec uv run --project "$REPO_DIR" $uv_flags "$REPO_DIR/gui_generate.py" "$@"
        ;;
    generate)
        exec uv run --project "$REPO_DIR" $uv_flags "$REPO_DIR/generate_image.py" "$@"
        ;;
    img2img)
        # img2img is generate_image.py with an input image — same script,
        # the -i flag is what switches the mode. This alias makes intent clear.
        exec uv run --project "$REPO_DIR" $uv_flags "$REPO_DIR/generate_image.py" "$@"
        ;;
    upscale)
        exec uv run --project "$REPO_DIR" $uv_flags "$REPO_DIR/upscale_image.py" "$@"
        ;;
    download)
        exec uv run --project "$REPO_DIR" $uv_flags "$REPO_DIR/download_models.py" "$@"
        ;;
    python)
        exec uv run --project "$REPO_DIR" $uv_flags python "$@"
        ;;
    config)
        config_key="${1:-}"
        config_val="${2:-}"

        if [[ -z "$config_key" ]]; then
            conf_print_all
            exit 0
        fi

        # Getter: ./run config <key>
        if [[ -z "$config_val" ]]; then
            value=$(conf_read "$config_key")
            if [[ -z "$value" ]]; then
                echo "${config_key}: (not set)"
            else
                echo "${config_key}=${value}"
            fi
            exit 0
        fi

        # Setter: ./run config <key> <value>
        case "$config_key" in
            model)
                conf_validate_model "$config_val"
                conf_write model "$config_val"
                echo "model=${config_val}"
                ;;
            steps)
                conf_validate_positive_int steps "$config_val"
                conf_write steps "$config_val"
                echo "steps=${config_val}"
                conf_warn_if_distilled steps
                ;;
            guidance)
                conf_validate_positive_float guidance "$config_val"
                conf_write guidance "$config_val"
                echo "guidance=${config_val}"
                conf_warn_if_distilled guidance
                ;;
            width)
                conf_validate_dimension width "$config_val"
                conf_write width "$config_val"
                echo "width=${config_val}"
                ;;
            height)
                conf_validate_dimension height "$config_val"
                conf_write height "$config_val"
                echo "height=${config_val}"
                ;;
            *)
                die "Unknown config key '${config_key}'. Valid keys: model, steps, guidance, width, height"
                ;;
        esac
        ;;
    ""|--help|-h)
        usage
        ;;
    *)
        die "Unknown command '$cmd'. Run ./run for available commands."
        ;;
esac
